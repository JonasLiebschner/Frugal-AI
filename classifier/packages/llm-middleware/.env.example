# LLM Middleware
# Supports any OpenAI-compatible endpoint: OpenAI, Ollama, LiteLLM proxy, etc.

# Base URL of the OpenAI-compatible API
MIDDLEWARE_LLM_BASE_URL=https://api.openai.com/v1
# MIDDLEWARE_LLM_BASE_URL=http://ollama:11434/v1
# MIDDLEWARE_LLM_BASE_URL=http://localhost:4000/v1  # LiteLLM proxy

# API key (leave empty or set to any value for Ollama)
MIDDLEWARE_LLM_API_KEY=sk-...
# MIDDLEWARE_LLM_API_KEY=ollama

# Model name
MIDDLEWARE_LLM_MODEL=gpt-4o-mini
# MIDDLEWARE_LLM_MODEL=llama3
# MIDDLEWARE_LLM_MODEL=mistral

# Ports (one per middleware)
# PORT=3000  # simple-middleware
# PORT=3001  # onnx-middleware
# PORT=3002  # llm-middleware
