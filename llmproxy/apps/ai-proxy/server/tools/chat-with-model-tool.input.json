        "oneOf": [
          {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["system"] },
              "content": {
                "oneOf": [
                  { "type": "string", "description": "Simple string content." },
                  {
                    "type": "array",
                    "minItems": 1,
                    "description": "Ordered multimodal content parts. Each part must be either text or image_url.",
                    "items": {
                      "oneOf": [
