{
  "name": "llmproxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./nuxt.config.ts",
  "scripts": {
    "build": "npm --prefix ../.. run build",
    "build:test": "node ./scripts/run-tests.cjs --check",
    "dev": "npm --prefix ../.. run dev",
    "prepare": "npm --prefix ../.. run prepare",
    "start": "npm --prefix ../.. run start",
    "test": "node ./scripts/run-tests.cjs",
    "test:memory": "node --import tsx --expose-gc ./scripts/memory-soak.cjs",
    "test:chaos-memory": "node --import tsx --expose-gc ./scripts/chaos-memory-soak.cjs",
    "test:streams-500": "node --import tsx --expose-gc ./scripts/chaos-memory-soak.cjs --mode=active-streams --connections=500 --min-tokens=1000 --max-tokens=40000",
    "test:streams-500:dashboard": "node --import tsx --expose-gc ./scripts/chaos-memory-soak.cjs --mode=active-streams --connections=500 --min-tokens=1000 --max-tokens=40000 --proxy-port=4311 --hold-open",
    "typecheck": "npm --prefix ../.. run typecheck"
  },
  "dependencies": {
    "ai-client": "1.0.0",
    "ai-proxy": "1.0.0",
    "ai-server": "1.0.0",
    "code-editor": "1.0.0",
    "markdown-it": "^14.1.1",
    "mcp-server": "1.0.0",
    "nuxt": "^4.3.1",
    "sse": "1.0.0",
    "tool-registry": "1.0.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.14",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3",
    "vue-tsc": "^3.2.5"
  }
}
